generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  company String?
  giftId  String? @db.ObjectId
}

model Gift {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  available Boolean @default(true)
}
